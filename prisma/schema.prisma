generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id            String   @id @default(cuid())
  email         String   @unique
  password      String?  // null si la cuenta se creó solo con Google
  name          String
  phone         String?
  role          String   @default("CLIENT")   // CLIENT | VENDOR | ADMIN
  avatar            String?
  googleId          String?  @unique // subject ID de Google — presente si hizo login/signup con Google
  googleEmail       String?  // email que devuelve Google (puede diferir del email de la cuenta)
  isActive          Boolean  @default(true)
  emailVerified     Boolean  @default(false)
  emailVerifiedAt   DateTime?
  twoFactorEnabled     Boolean   @default(false)
  twoFactorSecret      String?
  twoFactorBackupCodes String[]  @default([])
  twoFactorVerifiedAt  DateTime?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  businesses            Business[]
  bookings              Booking[]
  reviews               Review[]
  payments              Payment[]
  subscriptions         Subscription[]
  featuredPayments      FeaturedPayment[]
  passwordResetTokens   PasswordResetToken[]
  emailVerificationTokens EmailVerificationToken[]
  refreshTokens         RefreshToken[]
  reports               Report[]

  @@index([email])
  @@index([role])
  @@map("users")
}

model EmailVerificationToken {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([token])
  @@index([userId])
  @@map("email_verification_tokens")
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([token])
  @@index([userId])
  @@map("password_reset_tokens")
}

enum BusinessOrderMode {
  APPOINTMENT
  ORDER
}

model Business {
  id           String   @id @default(cuid())
  name         String
  description  String?
  category     String
  orderMode    BusinessOrderMode @default(APPOINTMENT)
  address      String
  city         String
  latitude     Float?
  longitude    Float?
  phone        String
  email        String?
  slogan       String?
  logo         String?
  coverImage         String?
  heroBannerImageUrl String?
  isActive     Boolean  @default(true)
  status       String   @default("active")   // active | suspended
  featured     Boolean  @default(false)
  featuredUntil DateTime?
  rating       Float?
  totalReviews Int?     @default(0)
  viewCount    Int      @default(0)
  featuredReminderSentAt DateTime? // fecha en que se envió el aviso de 3 días; null = no enviado aún
  // Cobros directos por negocio (PREMIUM)
  paymentInstructions  String?   // texto libre: Yape, transferencia, contra entrega…
  culqiPublicKey       String?   // pk_live_* o pk_test_*
  culqiSecretKeyEnc    String?   // sk cifrada AES-256-GCM (formato iv:tag:ciphertext)
  culqiKeysValidatedAt DateTime? // null = sin llaves válidas → pago directo
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  ownerId       String
  owner         User            @relation(fields: [ownerId], references: [id])
  services      Service[]
  subcategories Subcategory[]
  bookings      Booking[]
  reviews       Review[]
  businessHours       BusinessHours[]
  photos              BusinessPhoto[]
  availabilityBlocks  AvailabilityBlock[]
  featuredPayments    FeaturedPayment[]
  reports             Report[]

  @@index([ownerId])
  @@index([category])
  @@index([city])
  @@index([isActive])
  @@index([status])
  @@index([isActive, category])        // búsqueda pública por categoría
  @@index([isActive, city])            // búsqueda pública por ciudad
  @@index([isActive, category, city])  // búsqueda pública combinada
  @@index([isActive, rating])          // ordenar por rating en el home
  @@index([featured, featuredUntil])   // negocios destacados vigentes
  @@map("businesses")

}

model FeaturedPayment {
  id            String   @id @default(cuid())
  period        String                        // "7days" | "15days" | "30days"
  days          Int
  amount        Decimal  @db.Decimal(10, 2)
  culqiChargeId String
  featuredUntil DateTime
  createdAt     DateTime @default(now())

  businessId String
  business   Business @relation(fields: [businessId], references: [id])
  userId     String
  user       User     @relation(fields: [userId], references: [id])

  @@index([businessId])
  @@index([userId])
  @@index([createdAt])
  @@map("featured_payments")
}

model BusinessHours {
  id        String   @id @default(cuid())
  dayOfWeek Int      // 0=Dom, 1=Lun, ..., 6=Sáb
  openTime  String   // "09:00"
  closeTime String   // "18:00"
  isClosed  Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  businessId String
  business   Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  @@unique([businessId, dayOfWeek])
  @@map("business_hours")
}

model BusinessPhoto {
  id        String   @id @default(cuid())
  url       String
  caption   String?
  order     Int      @default(0)
  createdAt DateTime @default(now())

  businessId String
  business   Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  @@index([businessId])
  @@map("business_photos")
}

model Subcategory {
  id          String   @id @default(cuid())
  name        String
  description String?
  category    String   // matches the business/service category string
  position    Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  businessId  String
  business    Business  @relation(fields: [businessId], references: [id], onDelete: Cascade)
  services    Service[]

  @@index([businessId])
  @@index([businessId, category])
  @@map("subcategories")
}

model Service {
  id          String   @id @default(cuid())
  name        String
  description String?
  price       Decimal  @db.Decimal(10, 2)
  duration    Int?
  category    String
  photo       String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  businessId    String
  business      Business     @relation(fields: [businessId], references: [id], onDelete: Cascade)
  subcategoryId String?
  subcategory   Subcategory? @relation(fields: [subcategoryId], references: [id], onDelete: SetNull)
  bookings      Booking[]
  reports       Report[]

  @@index([businessId])
  @@index([isActive])
  @@index([subcategoryId])
  @@map("services")
}

model Booking {
  id           String   @id @default(cuid())
  date         DateTime
  status       String   @default("PENDING")  // PENDING | CONFIRMED | COMPLETED | CANCELLED
  totalAmount  Decimal  @db.Decimal(10, 2)
  commission   Decimal  @db.Decimal(10, 2)
  vendorAmount Decimal  @db.Decimal(10, 2)
  notes        String?
  deliveryAddress String? // solo para negocios ORDER (pedidos con entrega)
  paymentConfirmedAt DateTime?
  completedAt        DateTime?
  cancelledAt        DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  clientId   String
  client     User     @relation(fields: [clientId], references: [id])
  businessId String
  business   Business @relation(fields: [businessId], references: [id])
  serviceId  String
  service    Service  @relation(fields: [serviceId], references: [id])
  payment    Payment?
  review     Review?
  timeline   BookingTimeline[]

  @@index([clientId])
  @@index([businessId])
  @@index([status])
  @@index([date])
  @@index([businessId, date])          // disponibilidad y conflictos de horario
  @@index([businessId, date, status])  // conflicto: status IN [PENDING,CONFIRMED] + fecha
  @@index([clientId, status])          // historial de reservas del cliente por estado
  @@map("bookings")
}

model BookingTimeline {
  id          String   @id @default(cuid())
  event       String   // CREATED | PAYMENT_CONFIRMED | STATUS_UPDATED | CANCELLED | COMPLETED | REVIEW_LEFT
  description String?
  actor       String   @default("system") // "client" | "vendor" | "system"
  timestamp   DateTime @default(now())

  bookingId String
  booking   Booking @relation(fields: [bookingId], references: [id], onDelete: Cascade)

  @@index([bookingId])
  @@index([bookingId, timestamp])
  @@map("booking_timeline")
}

model Payment {
  id               String   @id @default(cuid())
  amount           Decimal  @db.Decimal(10, 2)
  currency         String   @default("PEN")
  status           String   @default("PENDING")  // PENDING | PAID | FAILED | REFUNDED
  provider         String
  providerId       String?  @unique // charge ID de Culqi — único: un cargo no puede aplicarse a 2 pagos
  commissionAmount Decimal  @db.Decimal(10, 2)
  vendorAmount     Decimal  @db.Decimal(10, 2)
  metadata         String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  bookingId String  @unique
  booking   Booking @relation(fields: [bookingId], references: [id])
  userId    String
  user      User    @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([status])
  @@index([userId, status])            // ingresos del vendor filtrados por estado
  @@index([userId, createdAt])         // historial de pagos del vendor por fecha
  @@map("payments")
}

model Subscription {
  id             String   @id @default(cuid())
  plan           String   @default("FREE")    // FREE | PRO | PREMIUM
  status         String   @default("ACTIVE")  // ACTIVE | CANCELLED | EXPIRED
  commissionRate Decimal  @db.Decimal(5, 4)
  maxServices    Int?
  price          Decimal  @db.Decimal(10, 2)
  culqiChargeId  String?                      // ID del cobro en Culqi para refunds
  isTrial        Boolean  @default(false)     // true = trial gratuito de 14 días
  isManualTrial  Boolean  @default(false)     // true = asignado manualmente por admin
  trialGrantedAt DateTime?                    // cuándo lo asignó el admin
  trialGrantedBy String?                      // userId del admin que lo asignó
  trialReason    String?                      // ej: "acquisition_pedidosya"
  startDate      DateTime @default(now())
  endDate        DateTime?
  autoRenew      Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  userId String
  user   User   @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([status])
  @@index([endDate])
  @@index([userId, status])            // planGuard: busca ACTIVE por userId (hit frecuente)
  @@index([status, endDate])           // cron de expiración: ACTIVE + endDate < now
  @@map("subscriptions")
}

model AvailabilityBlock {
  id         String   @id @default(cuid())
  businessId String
  business   Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  startDate  DateTime
  endDate    DateTime
  reason     String?
  createdAt  DateTime @default(now())

  @@index([businessId])
  @@index([startDate])
  @@index([businessId, startDate, endDate])  // rango de disponibilidad por negocio
  @@map("availability_blocks")
}

model AuditLog {
  id        String   @id @default(cuid())
  action    String                        // LOGIN, LOGOUT, ROLE_CHANGE, BUSINESS_TOGGLE, PAYMENT, FEATURED_PURCHASE, etc.
  userId    String?
  targetId  String?                       // ID del recurso afectado
  meta      String?                       // JSON con detalles extra
  ip        String?
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([action])
  @@index([createdAt])
  @@map("audit_logs")
}

model RefreshToken {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([token])
  @@index([userId])
  @@map("refresh_tokens")
}

model Review {
  id        String   @id @default(cuid())
  rating    Int
  comment   String?
  createdAt DateTime @default(now())

  clientId   String
  client     User     @relation(fields: [clientId], references: [id])
  businessId String
  business   Business @relation(fields: [businessId], references: [id])
  bookingId  String   @unique
  booking    Booking  @relation(fields: [bookingId], references: [id])

  @@index([businessId])
  @@index([clientId])
  @@map("reviews")
}

model Report {
  id                  String    @id @default(cuid())
  reason              String
  status              String    @default("open")   // open | resolved
  createdAt           DateTime  @default(now())
  resolvedAt          DateTime?

  reportedByUserId    String
  reportedBy          User      @relation(fields: [reportedByUserId], references: [id])
  reportedBusinessId  String?
  reportedBusiness    Business? @relation(fields: [reportedBusinessId], references: [id])
  reportedServiceId   String?
  reportedService     Service?  @relation(fields: [reportedServiceId], references: [id])

  @@index([status])
  @@index([reportedByUserId])
  @@index([reportedBusinessId])
  @@map("reports")
}

model Banner {
  id          String   @id @default(cuid())
  title       String
  imageUrl    String
  linkUrl     String?
  category    String   @default("ALL")   // "ALL" o categoría específica
  position    String   @default("home")  // "home" | "category"
  isActive    Boolean  @default(true)
  startsAt    DateTime @default(now())
  endsAt      DateTime?
  clickCount  Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([isActive, category])
  @@index([isActive, position])
  @@map("banners")
}
