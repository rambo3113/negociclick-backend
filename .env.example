# Copia este archivo a .env y completa los valores reales.
# NUNCA subas .env (con secretos reales) al repositorio.

# ─── BASE DE DATOS ────────────────────────────────────────────────────────────
DATABASE_URL="postgresql://user:password@host:5432/dbname?sslmode=require&pgbouncer=true&connection_limit=10&pool_timeout=20"
DIRECT_URL="postgresql://user:password@host:5432/dbname?sslmode=require"

# ─── SERVIDOR ─────────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development

# ─── JWT ──────────────────────────────────────────────────────────────────────
# Genera uno con: node -e "console.log(require('crypto').randomBytes(48).toString('base64'))"
JWT_SECRET=

# ─── 2FA TOTP ENCRYPTION ──────────────────────────────────────────────────────
# AES-256-GCM key para encriptar secrets TOTP. 64 hex chars = 32 bytes.
# Genera uno con: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
TOTP_ENCRYPTION_KEY=

# ─── CORS ─────────────────────────────────────────────────────────────────────
# En producción: dominio(s) real(es) del frontend, separados por coma.
ALLOWED_ORIGINS="http://localhost:3000,http://localhost:3001"

# ─── CULQI ────────────────────────────────────────────────────────────────────
# Obtén tus claves en: https://dashboard.culqi.com/developers/keys
# IMPORTANTE: usar claves de TEST (sk_test_/pk_test_) hasta validar todo el
# endurecimiento del flujo de pagos; recién entonces cambiar a LIVE.
CULQI_SECRET_KEY=

# Secreto del webhook — va como segmento en la URL (no query param):
# https://tudominio.com/api/payments/webhook/ESTE_SECRETO
# Configura esa misma URL completa en el panel de Culqi.
# Genera uno con: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
CULQI_WEBHOOK_SECRET=

# ─── CIFRADO DE LLAVES DE PAGO POR NEGOCIO ───────────────────────────────────
# AES-256-GCM key para cifrar las sk de Culqi de negocios PREMIUM. 64 hex chars.
# OBLIGATORIA: el servidor no arranca sin esta variable.
# Genera una con: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
PAYMENT_KEYS_ENCRYPTION_KEY=

# ─── EMAIL (Resend) ───────────────────────────────────────────────────────────
RESEND_API_KEY=
RESEND_FROM="NegociClick <onboarding@resend.dev>"

# URL pública del frontend — usada en links de emails (verificación, reset
# password, reseñas, etc). En producción: tu dominio real.
FRONTEND_URL="http://localhost:3000"

# ─── CLOUDINARY ───────────────────────────────────────────────────────────────
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ─── CHATBOT DE SOPORTE (Claude API) ───────────────────────────────────────────
ANTHROPIC_API_KEY=

# ─── GOOGLE OAUTH ─────────────────────────────────────────────────────────────
# Consola: https://console.cloud.google.com/apis/credentials
# El backend solo necesita el CLIENT_ID (verifica el ID token con audience =
# este valor). El CLIENT_SECRET lo usa next-auth en el frontend, no el backend.
GOOGLE_CLIENT_ID=
